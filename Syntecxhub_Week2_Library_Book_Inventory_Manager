# book.py

class Book:
    def __init__(self, book_id, title, author, is_issued=False, issued_to=None):
        self.book_id   = book_id
        self.title     = title
        self.author    = author
        self.is_issued = is_issued      # True if currently borrowed
        self.issued_to = issued_to      # Name of borrower

    def to_dict(self):
        """Convert Book object to dictionary for JSON saving."""
        return {
            "book_id":   self.book_id,
            "title":     self.title,
            "author":    self.author,
            "is_issued": self.is_issued,
            "issued_to": self.issued_to
        }

    @staticmethod
    def from_dict(data):
        """Create a Book object from a dictionary (loading from JSON)."""
        return Book(
            data["book_id"],
            data["title"],
            data["author"],
            data.get("is_issued", False),
            data.get("issued_to", None)
        )

    def __str__(self):
        status = f"Issued to: {self.issued_to}" if self.is_issued else "Available"
        return (f"| {self.book_id:<8} | {self.title:<25} | "
                f"{self.author:<20} | {status:<20} |")

