# library.py

import json
import os
from book import Book

FILE_PATH = "library.json"

class Library:
    def __init__(self):
        self.books = {}   # key: book_id, value: Book object
        self.load_from_file()

    # ---------- File I/O ----------

    def load_from_file(self):
        """Load books from JSON file on startup."""
        if os.path.exists(FILE_PATH):
            with open(FILE_PATH, "r") as f:
                data = json.load(f)
                for record in data:
                    b = Book.from_dict(record)
                    self.books[b.book_id] = b
        else:
            self.books = {}

    def save_to_file(self):
        """Save all books to JSON file."""
        with open(FILE_PATH, "w") as f:
            json.dump([b.to_dict() for b in self.books.values()], f, indent=4)

    # ---------- Add ----------

    def add_book(self, book_id, title, author):
        """Add a new book with unique ID validation."""
        if not book_id or not title or not author:
            print("\n❌ Error: All fields (ID, title, author) are required!")
            return False
        if book_id in self.books:
            print(f"\n❌ Error: Book ID '{book_id}' already exists!")
            return False

        self.books[book_id] = Book(book_id, title, author)
        self.save_to_file()
        print(f"\n✅ Book '{title}' added successfully!")
        return True

    # ---------- Search ----------

    def search_by_title(self, keyword):
        """Search books by title keyword (case-insensitive)."""
        keyword = keyword.lower()
        results = [b for b in self.books.values()
                   if keyword in b.title.lower()]
        self._print_results(results, f"title containing '{keyword}'")

    def search_by_author(self, keyword):
        """Search books by author keyword (case-insensitive)."""
        keyword = keyword.lower()
        results = [b for b in self.books.values()
                   if keyword in b.author.lower()]
        self._print_results(results, f"author containing '{keyword}'")

    def _print_results(self, results, label):
        """Helper to print search results in a formatted table."""
        if not results:
            print(f"\n⚠️  No books found with {label}.")
            return
        self._print_table(results)

    # ---------- Issue / Return ----------

    def issue_book(self, book_id, borrower_name):
        """Issue a book to a borrower."""
        if book_id not in self.books:
            print(f"\n❌ Error: Book ID '{book_id}' not found!")
            return False

        book = self.books[book_id]
        if book.is_issued:
            print(f"\n❌ '{book.title}' is already issued to {book.issued_to}!")
            return False

        book.is_issued = True
        book.issued_to = borrower_name
        self.save_to_file()
        print(f"\n✅ '{book.title}' issued to {borrower_name} successfully!")
        return True

    def return_book(self, book_id):
        """Return a previously issued book."""
        if book_id not in self.books:
            print(f"\n❌ Error: Book ID '{book_id}' not found!")
            return False

        book = self.books[book_id]
        if not book.is_issued:
            print(f"\n⚠️  '{book.title}' was not issued to anyone!")
            return False

        borrower = book.issued_to
        book.is_issued = False
        book.issued_to = None
        self.save_to_file()
        print(f"\n✅ '{book.title}' returned by {borrower} successfully!")
        return True

    # ---------- List / Reports ----------

    def list_all_books(self):
        """Display all books in a formatted table."""
        if not self.books:
            print("\n⚠️  No books in the library.")
            return
        self._print_table(list(self.books.values()))

    def show_report(self):
        """Show a simple summary report."""
        total    = len(self.books)
        issued   = sum(1 for b in self.books.values() if b.is_issued)
        available = total - issued

        print("\n" + "=" * 40)
        print("       📊 Library Report")
        print("=" * 40)
        print(f"  Total Books    : {total}")
        print(f"  Available      : {available}")
        print(f"  Issued Out     : {issued}")
        print("=" * 40)

        if issued > 0:
            print("\n  Currently Issued Books:")
            print("-" * 40)
            for book in self.books.values():
                if book.is_issued:
                    print(f"  [{book.book_id}] '{book.title}' → {book.issued_to}")
            print("-" * 40)

    # ---------- Helper ----------

    def _print_table(self, books):
        """Print a formatted table of books."""
        print("\n" + "=" * 85)
        print(f"| {'ID':<8} | {'Title':<25} | {'Author':<20} | {'Status':<20} |")
        print("=" * 85)
        for book in books:
            print(book)
        print("=" * 85)
        print(f"  Showing {len(books)} book(s).")

