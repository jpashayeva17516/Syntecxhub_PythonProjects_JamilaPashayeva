from library import Library

def print_menu():
    print("\n" + "=" * 38)
    print("   📚 Library Book Inventory Manager")
    print("=" * 38)
    print("  1. Add Book")
    print("  2. Search by Title")
    print("  3. Search by Author")
    print("  4. Issue Book")
    print("  5. Return Book")
    print("  6. List All Books")
    print("  7. Show Report")
    print("  8. Exit")
    print("=" * 38)

def main():
    library = Library()

    while True:
        print_menu()
        choice = input("Enter your choice (1-8): ").strip()

        if choice == "1":
            print("\n-- Add New Book --")
            bid    = input("Enter Book ID  : ").strip()
            title  = input("Enter Title    : ").strip()
            author = input("Enter Author   : ").strip()
            library.add_book(bid, title, author)

        elif choice == "2":
            print("\n-- Search by Title --")
            keyword = input("Enter title keyword: ").strip()
            library.search_by_title(keyword)

        elif choice == "3":
            print("\n-- Search by Author --")
            keyword = input("Enter author keyword: ").strip()
            library.search_by_author(keyword)

        elif choice == "4":
            print("\n-- Issue Book --")
            bid      = input("Enter Book ID       : ").strip()
            borrower = input("Enter Borrower Name : ").strip()
            library.issue_book(bid, borrower)

        elif choice == "5":
            print("\n-- Return Book --")
            bid = input("Enter Book ID to return: ").strip()
            library.return_book(bid)

        elif choice == "6":
            library.list_all_books()

        elif choice == "7":
            library.show_report()

        elif choice == "8":
            print("\n👋 Goodbye!")
            break

        else:
            print("\n⚠️  Invalid choice. Please enter a number between 1 and 8.")

if __name__ == "__main__":
    main()
